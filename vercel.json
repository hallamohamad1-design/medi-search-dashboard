{
  "version": 2,
  "buildCommand": "npm run build:prod",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "api/index.py": {
      "includeFiles": "BACK/app/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
