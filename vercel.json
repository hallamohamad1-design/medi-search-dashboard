{
  "version": 2,
  "buildCommand": "npm run build:prod",
  "outputDirectory": "dist/medi-search-dashboard/browser",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "api/index.py": {
      "includeFiles": "BACK/app/**"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
