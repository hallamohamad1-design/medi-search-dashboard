{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "DB_HOST":     "@db_host",
    "DB_NAME":     "@db_name",
    "DB_USER":     "@db_user",
    "DB_PASSWORD": "@db_password",
    "DB_PORT":     "@db_port",
    "DB_SSLMODE":  "@db_sslmode",
    "FRONTEND_URL":"@frontend_url"
  }
}
